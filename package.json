{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "packageManager": "npm@11.6.2",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "fn:secrets": "supabase secrets set GEMINI_API_KEY=$GEMINI_API_KEY SR_KEY=$SR_KEY NVIDIA_API_KEY=$NVIDIA_API_KEY --project-ref pimojkivimygenhygsto",
    "fn:deploy": "supabase functions deploy generate-lessons --project-ref pimojkivimygenhygsto --no-verify-jwt",
    "fn:invoke": "supabase functions invoke generate-lessons --project-ref pimojkivimygenhygsto",
    "fn:logs": "supabase functions logs generate-lessons --project-ref pimojkivimygenhygsto",
    "lessons:seed-starter:dry": "tsx scripts/seed-starter-lessons-from-topics.ts --dry-run",
    "lessons:seed-starter": "tsx scripts/seed-starter-lessons-from-topics.ts --commit",
    "graphify:dev": "node scripts/graphify-dev.cjs"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@supabase/supabase-js": "^2.100.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.14",
    "@types/dompurify": "^3.0.5",
    "@vitejs/plugin-react": "^5.0.4",
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "date-fns": "^4.1.0",
    "dexie": "^4.3.0",
    "dexie-react-hooks": "^4.2.0",
    "dompurify": "^3.4.7",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "framer-motion": "^12.38.0",
    "jsonrepair": "^3.13.3",
    "katex": "^0.16.44",
    "lucide-react": "^0.546.0",
    "mathjs": "^15.1.1",
    "mathlive": "^0.109.0",
    "motion": "^12.23.24",
    "onnxruntime-web": "^1.24.3",
    "postgres": "^3.4.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^3.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sonner": "^2.0.7",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "jsdom": "^27.1.0",
    "supabase": "^2.95.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.2.4"
  }
}
