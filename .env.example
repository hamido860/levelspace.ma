# Server-side AI provider configuration
# Never prefix these with VITE_ and never expose them to the browser.
GEMINI_API_KEY=
NVIDIA_API_KEY=
AI_PROVIDER=gemini
AI_FALLBACK_PROVIDER=nvidia
AI_FALLBACK_ENABLED=true
AI_PLATFORM_CREDITS_ENABLED=true
AI_KEYS_ENCRYPTION_SECRET=
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# Temporary developer/admin AI key exception.
# TODO(auth): remove after authenticated per-user keys are fully implemented.
# These keys are server-side only. The app exposes only boolean status.
NEXT_PUBLIC_ENABLE_DEV_ADMIN_AI_KEYS=false
DEV_ADMIN_AI_PROVIDER=openrouter
DEV_ADMIN_NVIDIA_API_KEY=
DEV_ADMIN_OPENROUTER_API_KEY=
DEV_ADMIN_GEMINI_API_KEY=

# Optional model overrides
GEMINI_MODEL=gemini-2.5-flash
NVIDIA_MODEL=google/gemma-3-27b-it
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# App URL
APP_URL=

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# New Supabase secret keys can be used instead of the legacy service_role key.
SUPABASE_SECRET_KEY=
