# Gemini AI — get key at aistudio.google.com
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"
# NVIDIA NIM (Gemma 3 fallback) — get key at build.nvidia.com
VITE_NVIDIA_API_KEY="MY_NVIDIA_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase Configuration
# Prefix with VITE_ for client-side access, or use without prefix for server-side proxy (more secure)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
