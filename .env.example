# Server-side AI provider configuration
# Never prefix API keys with VITE_ and never expose them to the browser.
GEMINI_API_KEY=AIza...
OPENROUTER_API_KEY=sk-or-v1-...
OPENAI_API_KEY=sk-...
NVIDIA_API_KEY=nvapi-...

# Must be a provider name: gemini | openrouter | openai | nvidia
AI_PROVIDER=gemini
AI_FALLBACK_PROVIDER=openrouter
AI_FALLBACK_ENABLED=false
AI_PLATFORM_CREDITS_ENABLED=true

# Required for saving user/admin API keys. Use at least 32 random characters.
AI_KEYS_ENCRYPTION_SECRET=replace-with-at-least-32-random-characters

# Temporary developer/admin AI key exception.
# TODO(auth): remove after authenticated per-user keys are fully implemented.
# Server reads ENABLE_DEV_ADMIN_AI_KEYS. Frontend may read VITE_ENABLE_DEV_ADMIN_AI_KEYS only as a boolean.
ENABLE_DEV_ADMIN_AI_KEYS=false
VITE_ENABLE_DEV_ADMIN_AI_KEYS=false
DEV_ADMIN_AI_PROVIDER=openrouter
DEV_ADMIN_GEMINI_API_KEY=
DEV_ADMIN_OPENROUTER_API_KEY=
DEV_ADMIN_OPENAI_API_KEY=
DEV_ADMIN_NVIDIA_API_KEY=

# Optional model overrides
GEMINI_MODEL=gemini-2.5-flash
NVIDIA_MODEL=google/gemma-3-27b-it
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# App URL
APP_URL=
VITE_API_PROXY_TARGET=http://127.0.0.1:4321

# Supabase client configuration. Vite exposes only VITE_* variables to the browser.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase server configuration. Service role key must stay server-only.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key
